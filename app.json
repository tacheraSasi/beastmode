{
  "expo": {
    "name": "beastmode",
    "slug": "beastmode",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icons/ios/AppIcon@3x.png",
    "scheme": "beastmode",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icons/ios/AppIcon~ios-marketing.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/icons/ios/AppIcon@3x.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/android/res/mipmap-xxxhdpi/ic_launcher_foreground.png",
        "backgroundImage": "./assets/images/icons/android/res/mipmap-xxxhdpi/ic_launcher_background.png",
        "monochromeImage": "./assets/images/icons/android/res/mipmap-xxxhdpi/ic_launcher_monochrome.png"
      },
      "package": "com.tach.beastmode"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      "expo-file-system",
      "expo-sharing",
      "expo-document-picker",
      "expo-image",
      "expo-av",
      "expo-local-authentication",
      "expo-secure-store",
      "expo-updates",
      "expo-build-properties",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "33715d47-d26f-4042-b05d-28553e82ebf5"
      }
    }
  }
}
